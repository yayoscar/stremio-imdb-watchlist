# Stremio Addon Configuration
# Copy this file to .env and set your actual values

# IMDb User ID (format: urXXXXXXX)
# Get your user ID from: https://www.imdb.com/profile or check your profile URL
IMDB_USER_ID=ur27472448

# Maximum number of items to display from watchlist
MAX_ITEMS=8

# Server configuration
PORT=7000

# Production domain (optional, for production deployment)
# Example: https://your-domain.com
# Leave empty for local development
HOST=

# API Keys
# Get OMDB API key from: http://www.omdbapi.com/apikey.aspx
OMDB_API_KEY=your_omdb_api_key_here

# Get TMDB API key from: https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_api_key_here

# Language for movie descriptions (e.g., es, en, pt)
TMDB_LANGUAGE=es
